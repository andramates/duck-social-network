<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.gui.MainMenuController"
            fx:id="root"
            stylesheets="@main.css">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="20"
              styleClass="header">

            <Label text="Duck Network"
                   styleClass="logo"/>

            <Region HBox.hgrow="ALWAYS"/>

            <StackPane>
                <Button text="Notifications"
                        styleClass="header-button"
                        onAction="#openNotifications"/>

                <Label fx:id="notificationBadge"
                       text="3"
                       styleClass="notification-badge"
                       StackPane.alignment="TOP_RIGHT"
                       translateX="6"
                       translateY="-6"/>
            </StackPane>

            <Button text="Profile"
                    styleClass="header-button"
                    onAction="#openProfile"/>

            <Button text="Logout"
                    styleClass="header-button"
                    onAction="#onLogout"/>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox spacing="10"
              styleClass="sidebar">

            <Button text="Chat"
                    styleClass="sidebar-button"
                    onAction="#openChat"/>

            <Button text="Friend Requests"
                    styleClass="sidebar-button"
                    onAction="#openFriendRequests"/>

            <Button text="Race Events"
                    styleClass="sidebar-button"
                    onAction="#openRaceEvents"/>

            <Button text="Communities"
                    styleClass="sidebar-button"
                    onAction="#openCommunities"/>

            <Button text="Ducks"
                    styleClass="sidebar-button"
                    onAction="#openDucks"/>

            <Button text="Users"
                    styleClass="sidebar-button"
                    onAction="#openUsers"/>

            <Button text="Friendships"
                    styleClass="sidebar-button"
                    onAction="#openFriendships"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <StackPane fx:id="contentArea"
                   styleClass="content-area">

            <Label text="Select a section from the menu"
                   styleClass="placeholder-text"/>

        </StackPane>
    </center>

</BorderPane>