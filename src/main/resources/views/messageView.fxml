<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.gui.MessageController"
            fx:id="root"
            stylesheets="@main.css">

    <!-- LEFT USERS -->
    <left>
        <VBox styleClass="chat-sidebar">

            <Label text="Chats" styleClass="sidebar-title"/>

            <ListView fx:id="usersListView"
                      styleClass="users-list"
                      VBox.vgrow="ALWAYS"
                      onMouseClicked="#onUserSelected"/>

        </VBox>
    </left>

    <!-- CENTER CHAT -->
    <center>
        <VBox spacing="0" styleClass="chat-container">

            <!-- HEADER -->
            <HBox styleClass="chat-header">
                <Label text="Conversation"
                       styleClass="chat-username"/>
            </HBox>

            <!-- MESSAGES (compatibil cu controller-ul) -->
            <ListView fx:id="messagesListView"
                      VBox.vgrow="ALWAYS"
                      onMouseClicked="#onMessageSelected"/>

            <!-- REPLY INFO -->
            <HBox spacing="10" style="-fx-padding: 5 15;">
                <Label fx:id="replyLabel"
                       visible="false"/>
                <Button fx:id="cancelReplyBtn"
                        text="Cancel"
                        visible="false"
                        onAction="#onCancelReply"/>
            </HBox>

            <!-- INPUT -->
            <HBox spacing="10" styleClass="chat-input-area">

                <TextArea fx:id="messageBox"
                          promptText="Type a message..."
                          prefRowCount="2"
                          HBox.hgrow="ALWAYS"/>

                <Button text="Send"
                        onAction="#onSend"
                        styleClass="primary-button"/>

            </HBox>

        </VBox>
    </center>

</BorderPane>