<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.gui.RaceEventController"
            stylesheets="@main.css">

    <!-- HEADER -->
    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="20"
              styleClass="content-header">

            <Label text="Race Events"
                   styleClass="section-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Add Race Event"
                    onAction="#onAddRaceEvent"
                    styleClass="primary-button"/>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="25"
              styleClass="content-area">

            <!-- TABLE CARD -->
            <VBox styleClass="card" VBox.vgrow="ALWAYS">

                <TableView fx:id="table"
                           VBox.vgrow="ALWAYS"
                           styleClass="modern-table">

                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="80"/>
                        <TableColumn fx:id="colTitle" text="Title" prefWidth="250"/>
                        <TableColumn fx:id="colDucks" text="Nr Ducks" prefWidth="150"/>
                    </columns>

                </TableView>

            </VBox>

            <!-- ACTION BUTTONS -->
            <HBox spacing="20"
                  alignment="CENTER"
                  styleClass="action-bar">

                <Button fx:id="btnSubscribe"
                        text="Subscribe"
                        onAction="#onSubscribe"
                        styleClass="primary-button"/>

                <Button fx:id="btnUnsubscribe"
                        text="Unsubscribe"
                        onAction="#onUnsubscribe"
                        styleClass="secondary-button"/>

                <Button fx:id="btnStartRace"
                        text="Start Race"
                        onAction="#onStartRace"
                        styleClass="danger-button"/>

            </HBox>

        </VBox>
    </center>

</BorderPane>