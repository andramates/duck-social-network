<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.gui.ProfilePageController">

    <center>
        <VBox spacing="20"
              alignment="CENTER"
              style="-fx-padding: 30;">

            <!-- Profile image -->
            <ImageView fx:id="profileImage"
                       fitWidth="140"
                       fitHeight="140"
                       preserveRatio="true"
                       style="-fx-border-radius: 70;"/>

            <!-- Username -->
            <Label fx:id="lblUsername"
                   style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

            <!-- Stats -->
            <HBox spacing="40" alignment="CENTER">
                <VBox alignment="CENTER">
                    <Label fx:id="lblFriends"
                           style="-fx-font-size: 16px;"/>
                    <Label text="Friends" style="-fx-text-fill: gray;"/>
                </VBox>


                <VBox alignment="CENTER">
                    <Label fx:id="lblSubscriptions"
                           style="-fx-font-size: 16px;"/>
                    <Label text="Subscriptions" style="-fx-text-fill: gray;"/>
                </VBox>

                <VBox alignment="CENTER">
                    <Label fx:id="lblType"
                           style="-fx-font-size: 16px;"/>
                    <Label text="Type" style="-fx-text-fill: gray;"/>
                </VBox>
            </HBox>

            <Separator prefWidth="300"/>

            <!-- Info -->
            <VBox spacing="8" alignment="CENTER">
                <Label fx:id="lblEmail"/>
                <Label fx:id="lblUserId"
                       style="-fx-text-fill: gray;"/>
            </VBox>

        </VBox>
    </center>

</BorderPane>
