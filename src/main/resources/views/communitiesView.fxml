<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.gui.CommunityController">

    <center>
        <VBox spacing="25" alignment="CENTER" style="-fx-padding: 30;">

<!--            <Label text="COMMUNITIES" style="-fx-font-size: 22px;"/>-->

            <HBox spacing="10" alignment="CENTER">
                <Button text="Show Number of Communities" onAction="#showNumCommunities"/>
                <Label fx:id="labelNumCommunities" style="-fx-font-size: 16px;"/>
            </HBox>

            <Separator prefWidth="400"/>

            <VBox spacing="10" alignment="CENTER">
                <Button text="Show Most Sociable Community" onAction="#showMostSociable"/>

                <TableView fx:id="tableCommunity" prefWidth="450">
                    <columns>
                        <TableColumn fx:id="colId" text="Id" prefWidth="60"/>
                        <TableColumn fx:id="colUsername" text="Username" prefWidth="150"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </center>

</BorderPane>
