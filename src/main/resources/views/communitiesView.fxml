<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ui.gui.CommunityController"
            stylesheets="@main.css">

    <center>
        <VBox spacing="30" styleClass="content-area">

            <!-- HEADER -->
            <Label text="Communities"
                   styleClass="section-title"/>

            <!-- STATS CARD -->
            <VBox spacing="15" styleClass="card">

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Button text="Show Number of Communities"
                            onAction="#showNumCommunities"
                            styleClass="primary-button"/>

                    <Label fx:id="labelNumCommunities"
                           styleClass="stat-number"/>
                </HBox>

            </VBox>

            <!-- MOST SOCIABLE CARD -->
            <VBox spacing="20" styleClass="card">

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Button text="Show Most Sociable Community"
                            onAction="#showMostSociable"
                            styleClass="primary-button"/>
                </HBox>

                <TableView fx:id="tableCommunity"
                           VBox.vgrow="ALWAYS"
                           styleClass="modern-table">

                    <columns>
                        <TableColumn fx:id="colId" text="Id" prefWidth="80"/>
                        <TableColumn fx:id="colUsername" text="Username" prefWidth="180"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="220"/>
                    </columns>

                </TableView>

            </VBox>

        </VBox>
    </center>

</BorderPane>